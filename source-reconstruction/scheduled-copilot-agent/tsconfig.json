{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "lib": ["es2022"],
    "moduleResolution": "node",
    "outDir": "out",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": true,
    "allowJs": true,
    "types": ["node", "vscode"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "src/**/*.js"],
  "exclude": ["out", "node_modules"]
}
